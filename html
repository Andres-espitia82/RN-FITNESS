<script>
  // Tus credenciales reales de RN FITNESS
  const firebaseConfig = {
    apiKey: "AIzaSyAz-SheUpUys4z_z4cf32B-T29NSx7epGw",
    authDomain: "rn-fitness-97201.firebaseapp.com",
    projectId: "rn-fitness-97201",
    storageBucket: "rn-fitness-97201.firebasestorage.app",
    messagingSenderId: "360552955791",
    appId: "1:360552955791:web:3e29109e778dc257c615fa",
    measurementId: "G-CM7BNTEMBW"
  };

  // Inicializamos Firebase y la Base de Datos (Firestore)
  firebase.initializeApp(firebaseConfig);
  const db = firebase.firestore();

  // ID del cliente que usará esta app (puedes cambiarlo si vendes otra copia)
  const MI_ID_PROVEEDOR = "gimnasio_valencia"; 

 // Escuchar cambios en la base de datos en tiempo real
  db.collection("licencias").doc(MI_ID_PROVEEDOR).onSnapshot((doc) => {
      if (doc.exists) {
          const datos = doc.data();
          if (datos.activo === false) {
              // Si está inactivo, creamos y mostramos la pantalla de bloqueo encima de todo
              if (!document.getElementById("pantalla-bloqueo-realtime")) {
                  const overlay = document.createElement("div");
                  overlay.id = "pantalla-bloqueo-realtime";
                  overlay.innerHTML = `
                      <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: #111; color: white; font-family: sans-serif; text-align: center; padding: 20px; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 999999;">
                          <h1 style="color: #ff4444; font-size: 28px; margin-bottom: 10px;">⚠️ Servicio Suspendido</h1>
                          <p style="font-size: 16px; color: #aaa; max-width: 400px; line-height: 1.5;">Esta aplicación ha sido desactivada temporalmente por administración.</p>
                          <p style="font-size: 13px; color: #666; margin-top: 20px;">Por favor, póngase en contacto con el soporte de RN FITNESS.</p>
                      </div>
                  `;
                  document.body.appendChild(overlay);
              }
          } else {
              // Si vuelve a estar activo (true), removemos el bloqueo de inmediato sin reiniciar la app
              const overlay = document.getElementById("pantalla-bloqueo-realtime");
              if (overlay) {
                  overlay.remove();
              }
          }
      } else {
          console.log("El proveedor no existe en la base de datos de Firebase.");
      }
      
  });
  
</script>
