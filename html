        <div id="view-active-workout" class="app-view view-hidden">
            <div class="active-workout-control-header" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 5px; margin-bottom: 15px; border-bottom: 1px solid #222;">
                <button onclick="cancelarEntrenamiento()" style="background: none; border: none; color: #ff3333; font-size: 20px; font-weight: bold; cursor: pointer; padding: 5px 10px;">✕</button>
                <div id="workout-timer" style="font-size: 24px; font-weight: bold; font-family: monospace; color: #fff; background: #111; padding: 4px 14px; border-radius: 6px; border: 1px solid #333;">00:00</div>
                <button onclick="terminarEntrenamiento()" style="background: #ff3333; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 14px;">Terminar</button>
            </div>

            <div class="exercise-navigator" id="exercise-navigator"></div>

            <div class="active-exercise-content">
                <div class="active-actions">
                    <button class="btn-active-action" onclick="mostrarModalGenerico('Guía', 'El video de este ejercicio estará disponible pronto.')">▶ Guía</button>
                    <button class="btn-active-action btn-danger-action" onclick="cancelarEntrenamiento()">🗑 Borrar</button>
                </div>

                <h2 id="active-exercise-title">Nombre Ejercicio</h2>
                <p id="active-exercise-note">Agregar una nota...</p>

                <div class="sets-table-container">
                    <div class="sets-header">
                        <div class="col-ser">SER...</div>
                        <div class="col-prev">PREVIA</div>
                      <div class="col-input" id="label-kg">KG</div>
                        <div class="col-input" id="label-reps">REPES</div>
                        <div class="col-check"></div>
                    </div>
                    <div id="sets-rows-container"></div>
                    <button class="btn-add-set" onclick="añadirSerieExtra()">+ Añadir Serie</button>
                </div>
            </div>
        </div>

        <div id="view-summary" class="app-view view-hidden">
            <div class="detail-header-area" style="text-align: center; margin-top: 30px;">
                <h1>¡Entrenamiento Completado!</h1>
                <p>Modo Bestia: Desactivado 🏆</p>
            </div>
            
            <div class="summary-stats-box">
                <div class="stat-item">
                    <h3 id="summary-time">00:00</h3>
                    <span>Tiempo</span>
                </div>
                <div class="stat-item">
                    <h3 id="summary-vol">0 kg</h3>
                    <span>Volumen Total</span>
                </div>
            </div>

            <div class="improvements-section">
                <h3>Resumen de Marcas</h3>
                <div id="summary-improvements-list"></div>
            </div>

            <button class="btn-start-workout" style="margin-top: 40px; position: relative;" onclick="cambiarSeccion('home')">Volver al Inicio</button>
        </div>

        <nav class="bottom-nav" id="main-bottom-nav">
            <div class="nav-item active" id="nav-btn-home" onclick="cambiarSeccion('home')">
                <canvas id="nav-icon-train" width="24" height="24"></canvas>
                <span class="nav-label">Entrenar</span>
            </div>
            <div class="nav-item center-btn" onclick="crearRutinaManualCompleta()">
                <div class="plus-circle"><canvas id="nav-icon-plus" width="24" height="24"></canvas></div>
            </div>
            <div class="nav-item" id="nav-btn-profile" onclick="cambiarSeccion('profile')">
                <canvas id="nav-icon-profile" width="24" height="24"></canvas>
                <span class="nav-label">Perfil</span>
            </div>
        </nav>

    </div>

    <script src="app.js"></script>
</body>
</html>
